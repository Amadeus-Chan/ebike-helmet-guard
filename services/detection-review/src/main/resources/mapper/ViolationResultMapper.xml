<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="net.czming.detection.review.mapper.ViolationResultMapper">
    <insert id="batchInsertViolationResult">
        insert into violation_result(record_id, license_plate, violation_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
        (#{item.recordId}, #{item.licensePlate}, #{item.violationTime})
        </foreach>
    </insert>
</mapper>