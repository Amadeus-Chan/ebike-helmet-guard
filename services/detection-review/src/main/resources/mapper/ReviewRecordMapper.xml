<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="net.czming.detection.review.mapper.ReviewRecordMapper">
    <insert id="insertReviewRecord" useGeneratedKeys="true" keyProperty="id">
        insert into review_record(camera_id, detected_image, violated, review_time, capture_time)
        VALUES (#{cameraId}, #{detectedImage}, #{violated}, #{reviewTime}, #{captureTime})
    </insert>

    <update id="updateViolated">
        update review_record
        <set>
            violated = #{violated}
        </set>
        <where>
            id = #{id}
        </where>
    </update>
</mapper>